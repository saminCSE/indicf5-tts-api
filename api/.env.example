PORT=3000
MONGO_URI=mongodb://localhost:27017/indicf5-tts
REDIS_HOST=localhost
REDIS_PORT=6380
# namespace BullMQ keys per environment (two workers on one Redis with the
# same prefix will compete for jobs)
BULL_PREFIX=bull

# mock  — silence WAVs, zero setup (default; tests/CI/reviewer quick-start)
# space — official HF Space via @gradio/client (no local ML; shared infra,
#         cold starts, currently broken upstream — see README)
# local — own Python model server in worker/ (production path)
TTS_BACKEND=mock
TTS_MAX_CHARS=1000
QUEUE_MAX_DEPTH=100
JOB_TIMEOUT_MS=120000
# local backend: URL of the Python model server
TTS_SERVICE_URL=http://localhost:8000

# Required for space/local backends: HF account with access granted to the
# gated ai4bharat/IndicF5 repo (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Optional voice override (space backend): any short WAV + its exact transcript
# HF_SPACE_ID=ai4bharat/IndicF5
# REF_AUDIO_URL=
# REF_TEXT=
